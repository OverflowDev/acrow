# ─── Wallet Connect ─────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── Contract ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Chain Config ────────────────────────────────────────────────────────────
# Hardhat local: 31337 | Sepolia: 11155111 | ARC Network: your_chain_id
NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337

# ARC Network (custom chain)
NEXT_PUBLIC_ARC_CHAIN_ID=your_arc_chain_id
NEXT_PUBLIC_ARC_RPC_URL=https://your-arc-rpc-url
NEXT_PUBLIC_ARC_EXPLORER_URL=https://your-arc-explorer

# ─── Supabase (off-chain metadata) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Hardhat Deployment (server-side only) ───────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_key
ARC_RPC_URL=https://your-arc-rpc-url
ARC_CHAIN_ID=your_arc_chain_id
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_NEVER_COMMIT
ETHERSCAN_API_KEY=your_etherscan_api_key
