# ─── WalletConnect ───────────────────────────────────────────────────────────
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── Contract ─────────────────────────────────────────────────────────────────
# Update this after running: npm run deploy:arc
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Active Chain ─────────────────────────────────────────────────────────────
# 31337 = Hardhat local | 11155111 = Sepolia | 5042002 = Arc Testnet
NEXT_PUBLIC_DEFAULT_CHAIN_ID=5042002

# ─── Arc Testnet ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
# URL: base URL only — no /rest/v1/ suffix
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — SERVER ONLY, never expose to the browser.
# Used by /api/messages to bypass RLS after verifying wallet ownership.
# Get from: Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Hardhat / Deploy ─────────────────────────────────────────────────────────
# NEVER commit a real private key. Fund deployer from https://faucet.circle.com
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_NEVER_COMMIT
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_key
ETHERSCAN_API_KEY=your_etherscan_api_key
